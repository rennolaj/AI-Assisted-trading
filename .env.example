# Mvp.Trading Configuration

# TradingView Webhook
TRADINGVIEW_WEBHOOK_SECRET=your-webhook-secret-here

# PostgreSQL Database
# NOTE: docker-compose provisions the container database as "ai-trading-db" —
# keep the Database= value in sync with it (a mismatched name fails at runtime
# with "database does not exist"). For docker compose runs use Host=postgres.
POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=ai-trading-db;Username=postgres;Password=postgres

# Redis
REDIS_CONNECTION_STRING=localhost:6379

# Kraken Futures (Demo Environment)
# Get your demo API credentials at: https://demo-futures.kraken.com/
KRAKEN_FUTURES_API_KEY=your-demo-api-key-here
KRAKEN_FUTURES_API_SECRET=your-demo-api-secret-here
KRAKEN_FUTURES_BASE_URL=https://demo-futures.kraken.com/derivatives
KRAKEN_FUTURES_AUTH_BASE_URL=https://demo-futures.kraken.com/derivatives

# Kraken Futures Integration Tests
# Set to 1 to enable integration tests (requires valid API credentials above)
KRAKEN_FUTURES_TRADING_TESTS=0
KRAKEN_FUTURES_TEST_SYMBOL=PF_XBTUSD

# MCP / LLM Provider
MCP_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
MCP_FORCE_ALLOW=false

# Execution Settings
EXECUTION_MODE=SIMULATED
# Options: SIMULATED, KRAKEN_DEMO, KRAKEN_LIVE
# Use SIMULATED for testing without real orders
# Use KRAKEN_DEMO for demo trading with paper money
# Use KRAKEN_LIVE only when ready for production

# Risk Settings
RISK_MAX_POSITION_SIZE_USD=10000
RISK_MAX_DAILY_LOSS_USD=500
RISK_PERCENT_PER_TRADE=0.02

# Logging
LOG_LEVEL=Information

# =============================================================================
# ngrok Configuration (Optional)
# =============================================================================
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
