{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ElliottCandidates.schema.json",
  "title": "ElliottCandidates",
  "type": "object",
  "additionalProperties": false,
  "required": ["baseTimeframe", "candidates"],
  "properties": {
    "baseTimeframe": { "$ref": "#/$defs/timeframe" },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/elliottCandidate" }
    }
  },
  "$defs": {
    "timeframe": {
      "type": "string",
      "enum": ["M1", "M5", "M15", "H1", "H4", "D1"]
    },
    "ruleViolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule", "severity", "details"],
      "properties": {
        "rule": { "type": "string" },
        "severity": { "type": "string" },
        "details": { "type": "string" }
      }
    },
    "invalidationLevels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["longInvalidationPrice", "shortInvalidationPrice"],
      "properties": {
        "longInvalidationPrice": { "type": ["number", "null"] },
        "shortInvalidationPrice": { "type": ["number", "null"] }
      }
    },
    "elliottCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateId",
        "patternType",
        "waveLabel",
        "score",
        "confidence",
        "ruleViolations",
        "invalidation"
      ],
      "properties": {
        "candidateId": { "type": "string" },
        "patternType": { "type": "string" },
        "waveLabel": { "type": "string", "enum": ["W3", "W5END", "OTHER"] },
        "score": { "type": "number" },
        "confidence": { "type": "number" },
        "ruleViolations": {
          "type": "array",
          "items": { "$ref": "#/$defs/ruleViolation" }
        },
        "invalidation": { "$ref": "#/$defs/invalidationLevels" }
      }
    }
  }
}
