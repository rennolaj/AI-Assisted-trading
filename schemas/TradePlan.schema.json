{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "TradePlan.schema.json",
  "title": "TradePlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planId",
    "symbol",
    "side",
    "timeframe",
    "entryType",
    "entryReferencePrice",
    "entryLimitPrice",
    "quantity",
    "stopLossPrice",
    "plannedRiskAmount",
    "takeProfitTargets",
    "riskPolicyVersion",
    "policyHash",
    "candidateId",
    "decisionReceipt",
    "createdAtUtc"
  ],
  "properties": {
    "planId": { "type": "string", "format": "uuid" },
    "symbol": { "type": "string" },
    "side": { "type": "string" },
    "timeframe": {
      "type": "string",
      "enum": ["M1", "M5", "M15", "M30", "H1", "H2", "H4", "H12", "D1"]
    },
    "entryType": { "type": "string" },
    "entryReferencePrice": { "type": "number" },
    "entryLimitPrice": { "type": "number" },
    "quantity": { "type": "number" },
    "stopLossPrice": { "type": "number" },
    "plannedRiskAmount": { "type": "number" },
    "takeProfitTargets": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/takeProfitTarget" }
    },
    "riskPolicyVersion": { "type": "string" },
    "policyHash": { "type": "string" },
    "candidateId": { "type": "string" },
    "decisionReceipt": { "type": "string" },
    "createdAtUtc": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "takeProfitTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["price", "quantity", "reason"],
      "properties": {
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "reason": { "type": "string" }
      }
    }
  }
}
