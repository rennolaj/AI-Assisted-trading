{
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=ai-trading-db"
  },
  "KrakenFutures": {
    "BaseUrl": "https://demo-futures.kraken.com/derivatives/api/v3",
    "ApiKey": "",
    "ApiSecret": "",
    "TimeoutSeconds": 10,
    "Cache": {
      "InstrumentsTtlSeconds": 300,
      "TickersTtlSeconds": 2,
      "CandlesTtlSeconds": 5
    },
    "RateLimit": {
      "MaxCostPerWindow": 500,
      "WindowSeconds": 10,
      "InstrumentsCost": 0,
      "TickersCost": 0,
      "CandlesCost": 0
    }
  },
  "SymbolMapping": {
    "KrakenFutures": {
      "BTCUSD.P": "PI_XBTUSD"
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "AlertQueueKey": "mvp:alerts"
  },
  "Indicator": {
    "Mode": "scalping_default"
  },
  "Worker": {
    "PollIntervalMs": 500,
    "TradeMonitorIntervalMs": 2000
  }
}
