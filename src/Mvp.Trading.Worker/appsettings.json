{
  "Postgres": {
    "ConnectionString": ""
  },
  "KrakenFutures": {
    "BaseUrl": "https://futures.kraken.com/derivatives/api/v3",
    "ApiKey": "",
    "ApiSecret": "",
    "TimeoutSeconds": 10,
    "Cache": {
      "InstrumentsTtlSeconds": 300,
      "TickersTtlSeconds": 2,
      "CandlesTtlSeconds": 5
    },
    "RateLimit": {
      "MaxCostPerWindow": 500,
      "WindowSeconds": 10,
      "InstrumentsCost": 0,
      "TickersCost": 0,
      "CandlesCost": 0
    }
  },
  "SymbolMapping": {
    "KrakenFutures": {}
  },
  "Redis": {
    "ConnectionString": "",
    "AlertQueueKey": "mvp:alerts"
  },
  "Indicator": {
    "Mode": "scalping_default",
    "LookbackDays": 1,
    "LookbackDaysByTimeframe": {
      "M5": 1,
      "M15": 1,
      "M30": 1,
      "H1": 2,
      "H2": 3
    }
  },
  "Elliott": {
    "BaseTimeframe": "M1",
    "LookbackDays": 1,
    "Parameters": {
      "PivotMethod": "ZigZag",
      "Depth": 12,
      "DeviationPct": 5,
      "MaxCandidates": 10
    },
    "Profiles": {
      "conservative": {
        "PivotMethod": "ZigZag",
        "Depth": 12,
        "DeviationPct": 5,
        "MaxCandidates": 10
      },
      "aggressive": {
        "PivotMethod": "ZigZag",
        "Depth": 6,
        "DeviationPct": 2,
        "MaxCandidates": 15
      }
    },
    "ProfileSelection": {
      "DefaultProfile": "conservative",
      "FallbackProfile": "aggressive",
      "RiskCategoryMap": {
        "SAFE": "conservative",
        "NORMAL": "conservative",
        "MODERATE": "aggressive",
        "HIGH": "aggressive"
      }
    },
    "TickSizeFallback": 0,
    "TickSizeOverrides": {}
  },
  "Worker": {
    "PollIntervalMs": 500,
    "TradeMonitorIntervalMs": 2000
  }
}
