{
  "Postgres": {
    "ConnectionString": ""
  },
  "KrakenFutures": {
    "BaseUrl": "https://futures.kraken.com/derivatives/api/v3",
    "ApiKey": "",
    "ApiSecret": "",
    "TimeoutSeconds": 10,
    "Cache": {
      "InstrumentsTtlSeconds": 300,
      "TickersTtlSeconds": 2,
      "CandlesTtlSeconds": 5
    },
    "RateLimit": {
      "MaxCostPerWindow": 500,
      "WindowSeconds": 10,
      "InstrumentsCost": 0,
      "TickersCost": 0,
      "CandlesCost": 0
    }
  },
  "SymbolMapping": {
    "KrakenFutures": {
      "BTCUSD.P": "PI_XBTUSD"
    }
  },
  "Redis": {
    "ConnectionString": "",
    "AlertQueueKey": "mvp:alerts"
  },
  "Indicator": {
    "Mode": "scalping_default"
  },
  "Elliott": {
    "BaseTimeframe": "M15",
    "Parameters": {
      "PivotMethod": "ZigZag",
      "Depth": 12,
      "DeviationPct": 5,
      "MaxCandidates": 10
    },
    "TickSizeFallback": 0,
    "TickSizeOverrides": {}
  },
  "Worker": {
    "PollIntervalMs": 500,
    "TradeMonitorIntervalMs": 2000
  }
}
